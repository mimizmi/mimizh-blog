---
import { slug } from 'github-slugger';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SidebarTree from '../../components/SidebarTree.astro';
import { buildNoteTree, findNode, getAncestors, getFolderColor } from '../../utils/tree';
import type { TreeNode } from '../../utils/tree';

export async function getStaticPaths() {
  const tree = await buildNoteTree();
  const paths: { params: { slug: string } }[] = [];

  function walk(nodes: TreeNode[], parent: string[]) {
    for (const node of nodes) {
      const segs = [...parent, node.name];
      paths.push({ params: { slug: segs.join('/') } });
      if (node.type === 'folder' && node.children) walk(node.children, segs);
    }
  }
  walk(tree, []);
  return paths;
}

const { slug: slugParam } = Astro.params;
const segments = (slugParam || '').split('/').filter(Boolean);

const tree = await buildNoteTree();
const node = findNode(tree, segments);

if (!node) return Astro.redirect('/notes/');

const ancestors = getAncestors(tree, segments);
const isNote = node.type === 'note';

// Breadcrumbs
const breadcrumbs = [
  { label: '笔记', href: '/notes/' },
  ...ancestors.map((a, i) => ({
    label: a.type === 'folder' ? a.name : (a.note?.data.title || ''),
    href: `/notes/${segments.slice(0, i + 1).join('/')}/`,
  })),
];

const pageTitle = isNote ? (node.note?.data.title || '') : node.name;

// For folder listing: collect notes directly in this folder + subfolder info
let folderChildren: TreeNode[] = [];
let folderNotes: TreeNode[] = [];
let directNoteCount = 0;
if (!isNote && node.children) {
  folderChildren = node.children;
  folderNotes = folderChildren.filter(c => c.type === 'note');
  directNoteCount = node.count;
}

// For note detail: render content
let Content: any;
let toc: { id: string; label: string; level: number }[] = [];
let noteEntry: any = null;

if (isNote && node.note) {
  noteEntry = node.note;
  const rendered = await node.note.render();
  Content = rendered.Content;

  const bodyText = node.note.body || '';
  const headingRe = /^(#{2,3})\s+(.+)$/gm;
  let match;
  while ((match = headingRe.exec(bodyText)) !== null) {
    toc.push({ id: slug(match[2]), label: match[2], level: match[1].length });
  }
}
---

<BaseLayout
  title={`${pageTitle} · 笔记`}
  activeNav="notes"
  breadcrumbs={breadcrumbs}
>
  <div class="main">
    <div class="sb">
      <div style="padding:.25rem 0 1rem">
        <div class="tree-sec">笔记</div>
        <SidebarTree nodes={tree} ancestors={ancestors} currentNode={node} basePath="/notes/" />
      </div>
    </div>

    {!isNote ? (
      /* ── Folder listing ── */
      <div class="main-col" style="overflow-y:auto;height:calc(100vh - var(--nav-h))">
        <div class="page fu">
          <div class="ph">
            <div class="pt" style="display:flex;align-items:center;gap:.5rem">
              <span style={`width:8px;height:8px;border-radius:50%;background:${getFolderColor(node.segments.join('/'))};display:inline-block`}></span>
              {node.name}
            </div>
            <div class="pd">{directNoteCount} 篇笔记</div>
          </div>

          {/* Sub-folders as cards */}
          {folderChildren.some(c => c.type === 'folder') && (
            <div class="cat-grid">
              {folderChildren.filter(c => c.type === 'folder').map(f => (
                <a class="cat-c" href={`/notes/${f.segments.join('/')}/`}>
                  <div class="cat-c-dot" style={`background:${getFolderColor(f.segments.join('/'))}`}></div>
                  <div class="cat-c-name">{f.name}</div>
                  <div class="cat-c-sub">{f.count} 篇笔记</div>
                  <div class="cat-c-meta">子文件夹</div>
                </a>
              ))}
            </div>
          )}

          {/* Direct notes */}
          {folderNotes.length > 0 && (
            <div class="fl">
              {folderNotes.map(n => (
                <a class="fr" href={`/notes/${n.segments.join('/')}/`}>
                  <div>
                    <div class="fn">{n.note?.data.title || n.name}</div>
                    <div class="fe">{n.note?.data.description || ''}</div>
                    {n.tags && n.tags.length > 0 && (
                      <div style="display:flex;gap:.2rem;flex-wrap:wrap;margin-top:.35rem">
                        {n.tags.map(t => <span class="proj-tag" style="font-size:calc(.58rem * var(--fs-ui))">{t}</span>)}
                      </div>
                    )}
                  </div>
                  <div class="fm-col">
                    <div class="fd">{n.resolvedDate || n.note?.data.date || ''}</div>
                    {(n.readingTime || n.note?.data.reading_time) && <div class="fd">{n.readingTime || n.note?.data.reading_time}</div>}
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    ) : (
      /* ── Note detail ── */
      <div style="flex:1;overflow-y:auto;height:calc(100vh - var(--nav-h))">
        <div class="doc-layout">
          <div class="doc-main fu">
            <a class="back" href={`/notes/${node.segments.slice(0, -1).join('/')}/`}>← 返回</a>
            <a class="doc-cat" href={`/notes/${node.segments.slice(0, -1).join('/')}/`}
              style={`color:${getFolderColor(node.segments.join('/'))}`}>
              {node.segments.slice(0, -1).join(' / ') || '笔记'}
            </a>
            <h1 class="doc-title">{noteEntry?.data.title}</h1>
            {noteEntry?.data.description && <div class="doc-sub">{noteEntry.data.description}</div>}
            <div class="doc-meta">
              <span>{node.resolvedDate || noteEntry?.data.date}</span>
              {(node.readingTime || noteEntry?.data.reading_time) && <><span>·</span><span>{node.readingTime || noteEntry?.data.reading_time}</span></>}
            </div>
            {node.tags && node.tags.length > 0 && (
              <div style="display:flex;gap:.28rem;flex-wrap:wrap;margin-top:-.5rem;margin-bottom:1rem">
                {node.tags.map(t => <span class="proj-tag">{t}</span>)}
              </div>
            )}
            <div class="doc-body">
              {Content && <Content />}
            </div>
          </div>
          {toc.length > 0 && (
            <div class="doc-toc-col">
              <div class="doc-toc-lbl">目录</div>
              <ul class="toc-ul">
                {toc.map(t => (
                  <li class={`toc-li${t.level === 3 ? ' h3' : ''}`} data-id={t.id}
                    onclick={`document.getElementById('${t.id}').scrollIntoView({behavior:'smooth',block:'start'})`}>
                    {t.label}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
